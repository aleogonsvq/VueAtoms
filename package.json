  "type": "module",
  "description": "Mi propio UI Kit atómico con estilo neón para Vue 3",
  "author": "Tu Nombre",
  "license": "MIT",
  
  "files": ["dist"],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": "./dist/index.css" 
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
